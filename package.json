    "@types/react-dom": "~19.1.0",
    "@types/three": "0.176.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^8.0.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
